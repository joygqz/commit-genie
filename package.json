{
  "publisher": "joygqz",
  "name": "commit-genie",
  "displayName": "Commit Genie",
  "version": "4.1.0",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "description": "Generate Conventional Commits messages with AI. Works with any OpenAI-compatible API.",
  "license": "MIT",
  "homepage": "https://github.com/joygqz/commit-genie#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/joygqz/commit-genie.git"
  },
  "bugs": {
    "url": "https://github.com/joygqz/commit-genie/issues"
  },
  "keywords": [
    "git",
    "commit",
    "commit message",
    "conventional commits",
    "gitmoji",
    "ai",
    "openai",
    "deepseek",
    "scm",
    "productivity"
  ],
  "categories": [
    "SCM Providers",
    "AI"
  ],
  "main": "./dist/extension.js",
  "icon": "./images/logo.png",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "dist/*",
    "images/*"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "category": "Commit Genie",
        "command": "commit-genie.generate",
        "title": "Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "category": "Commit Genie",
        "command": "commit-genie.selectModel",
        "title": "Select Model"
      }
    ],
    "configuration": {
      "title": "Commit Genie",
      "properties": {
        "commit-genie.baseURL": {
          "type": "string",
          "markdownDescription": "API endpoint. Any OpenAI-compatible service works, e.g. `https://api.openai.com/v1`, `https://api.deepseek.com`, `http://localhost:11434/v1` (Ollama).",
          "order": 0
        },
        "commit-genie.apiKey": {
          "type": "string",
          "description": "API key. Leave empty for local endpoints such as Ollama.",
          "order": 1
        },
        "commit-genie.model": {
          "type": "string",
          "markdownDescription": "Model ID, e.g. `deepseek-v4-pro`. Run `Commit Genie: Select Model` to pick from your provider.",
          "order": 2
        },
        "commit-genie.language": {
          "type": "string",
          "default": "English",
          "description": "Language for the subject and body, e.g. English, 简体中文, 日本語. Type, scope and code identifiers stay in English.",
          "order": 3
        },
        "commit-genie.useEmoji": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Prefix the commit type with a matching gitmoji, e.g. `✨ feat(api): add retry`.",
          "order": 4
        },
        "commit-genie.instructions": {
          "type": "string",
          "editPresentation": "multilineText",
          "description": "Extra instructions appended to the prompt, such as team conventions or ticket-number format.",
          "order": 5
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "commit-genie.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    }
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && pnpm run lint && node build.js --production",
    "compile": "pnpm run check-types && pnpm run lint && node build.js",
    "watch": "run-p watch:*",
    "watch:build": "node build.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "ext:package": "vsce package",
    "ext:publish": "vsce publish",
    "release": "bumpp -a"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/node": "~26.1.1",
    "@types/vscode": "~1.90.0",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.7.0",
    "lint-staged": "^17.1.0",
    "npm-run-all2": "^9.0.2",
    "rolldown": "^1.2.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check-types && pnpm exec lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
