{
  "publisher": "joygqz",
  "name": "commit-genie",
  "displayName": "Commit Genie",
  "version": "4.0.0",
  "packageManager": "pnpm@10.17.1",
  "description": "AI commit message generator. Works with any OpenAI-compatible API.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/joygqz/commit-genie#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/joygqz/commit-genie.git"
  },
  "bugs": {
    "url": "https://github.com/joygqz/commit-genie/issues"
  },
  "keywords": [
    "git",
    "commit",
    "commit message",
    "conventional commits",
    "gitmoji",
    "ai",
    "openai",
    "deepseek",
    "scm",
    "productivity"
  ],
  "categories": [
    "SCM Providers",
    "AI"
  ],
  "main": "./dist/extension.js",
  "icon": "./images/logo.png",
  "files": [
    "LICENSE",
    "dist/*",
    "images/*"
  ],
  "engines": {
    "vscode": "^1.84.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "category": "Commit Genie",
        "command": "commit-genie.generate",
        "title": "Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "category": "Commit Genie",
        "command": "commit-genie.selectModel",
        "title": "Select Model"
      }
    ],
    "configuration": {
      "title": "Commit Genie",
      "properties": {
        "commit-genie.baseURL": {
          "type": "string",
          "markdownDescription": "API endpoint. Any OpenAI-compatible service works, e.g. `https://api.openai.com/v1`, `https://api.deepseek.com`, `http://localhost:11434/v1` (Ollama).",
          "order": 0
        },
        "commit-genie.apiKey": {
          "type": "string",
          "description": "API key.",
          "order": 1
        },
        "commit-genie.model": {
          "type": "string",
          "markdownDescription": "Model ID. Run `Commit Genie: Select Model` to pick from your provider.",
          "order": 2
        },
        "commit-genie.language": {
          "type": "string",
          "default": "English",
          "description": "Commit message language, e.g. English, 简体中文, 日本語.",
          "order": 3
        },
        "commit-genie.useEmoji": {
          "type": "boolean",
          "default": false,
          "description": "Prefix the commit type with a matching gitmoji (✨ feat, 🐛 fix, …).",
          "order": 4
        },
        "commit-genie.instructions": {
          "type": "string",
          "editPresentation": "multilineText",
          "description": "Extra instructions appended to the prompt, e.g. team conventions or ticket-number format.",
          "order": 5
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "commit-genie.generate",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "ext:package": "vsce package",
    "ext:publish": "vsce publish",
    "release": "bumpp -a"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/node": "~22.18.8",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.6.2",
    "baseline-browser-mapping": "^2.10.36",
    "bumpp": "^10.2.3",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
